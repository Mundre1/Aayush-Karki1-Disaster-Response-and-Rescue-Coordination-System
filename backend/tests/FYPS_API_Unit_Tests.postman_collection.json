{
  "info": {
    "_postman_id": "c5f3f8d6-5ab2-4df8-9d2f-5e5d6b4f0901",
    "name": "FYPS API Unit Tests (5)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "UT-API-01 Health check returns 200",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has status ok', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      }
    },
    {
      "name": "UT-API-02 Register user with valid payload",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Response includes user object', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('user');",
              "  pm.expect(jsonData.user).to.have.property('email');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"UT API User\",\n  \"email\": \"ut_api_user_{{$timestamp}}@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9800000000\",\n  \"roleName\": \"citizen\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "UT-API-03 Register user with missing password returns 400",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 400', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Invalid User\",\n  \"email\": \"invalid_{{$timestamp}}@example.com\",\n  \"roleName\": \"citizen\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "UT-API-04 Profile without token returns 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "pm.test('Response mentions access token', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.message).to.include('token');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/auth/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "profile"
          ]
        }
      }
    },
    {
      "name": "UT-API-05 Login with invalid credentials returns 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "pm.test('Response contains invalid credentials message', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.message).to.include('Invalid credentials');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"no_user_{{$timestamp}}@example.com\",\n  \"password\": \"wrongPassword123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ]
}
